# Expo (client)
# For Expo Router apps, only variables prefixed with EXPO_PUBLIC_ are exposed to the client.
# REQUIRED: these must be set for the app to function.
# Find them in Supabase: Project Settings → API (Project URL + the publishable/anon key).
EXPO_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_publishable_anon_key_here
